{
  "name": "@aps/db",
  "version": "0.1.0",
  "private": true,
  "description": "APS Prisma schema + generated client",
  "main": "./src/generated/index.js",
  "types": "./src/generated/index.d.ts",
  "exports": {
    ".": {
      "require": "./src/generated/index.js",
      "import": "./src/generated/index.js",
      "types": "./src/generated/index.d.ts"
    },
    "./generated": {
      "require": "./src/generated/index.js",
      "import": "./src/generated/index.js",
      "types": "./src/generated/index.d.ts"
    }
  },
  "files": ["src/generated"],
  "scripts": {
    "build": "tsc --noEmit",
    "generate": "dotenv -e ../../.env.local -- prisma generate",
    "migrate": "dotenv -e ../../.env.local -- prisma migrate dev",
    "migrate:deploy": "dotenv -e ../../.env.local -- prisma migrate deploy",
    "typecheck": "tsc --noEmit",
    "seed": "dotenv -e ../../.env.local -- node prisma/seed.mjs",
    "seed:hosted": "node prisma/seed.mjs",
    "seed:demo": "dotenv -e ../../.env.local -- node prisma/seed-demo.mjs",
    "seed:demo:hosted": "node prisma/seed-demo.mjs"
  },
  "dependencies": {
    "@prisma/client": "5.22.0"
  },
  "devDependencies": {
    "prisma": "5.22.0",
    "typescript": "5.4.5"
  }
}
