# APS -- PLACEHOLDER KEYS ONLY. No real values here. [red line 1]
# Copy to .env.local (gitignored) and fill in real values.
# Variable names follow the AWS S3 SDK convention for reference;
# actual values must be sourced from your infra config (not committed).

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/aps_dev
REDIS_URL=redis://HOST:6379

S3_ENDPOINT=https://ENDPOINT
S3_BUCKET=BUCKET_NAME
S3_ACCESS_KEY_ID=PLACEHOLDER_KEY_ID
S3_SIGNING_KEY=PLACEHOLDER_SIGNING

# LLM provider -- provider TBD pending APS-004 gate. Default: "stub" (no API calls)
LLM_PROVIDER=stub
LLM_PROVIDER_API_KEY=PLACEHOLDER_PROVIDER_KEY
LLM_PROVIDER_BASE_URL=https://PROVIDER_API_URL

JWT_SECRET=PLACEHOLDER_JWT_VALUE

SUPPORT_EMAIL_FROM=no-reply@PLACEHOLDER
SUPPORT_EMAIL_SMTP_HOST=PLACEHOLDER
SUPPORT_EMAIL_SMTP_PORT=587
