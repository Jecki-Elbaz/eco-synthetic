{
  "name": "aps-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "AI Patient Simulator -- monorepo root (Sprint 1)",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @aps/db generate",
    "db:migrate": "pnpm --filter @aps/db migrate"
  },
  "devDependencies": {
    "dotenv-cli": "7.4.4",
    "turbo": "2.5.3",
    "typescript": "5.4.5"
  },
  "pnpm": {
    "overrides": {
      "typescript": "5.4.5"
    }
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
