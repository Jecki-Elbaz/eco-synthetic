{
  "name": "@aps/api",
  "version": "0.1.0",
  "private": true,
  "description": "APS NestJS API server",
  "scripts": {
    "build": "nest build",
    "start": "node dist/src/main.js",
    "dev": "nest start --watch",
    "dev:boot": "dotenv -e ../../.env.local -- node dist/src/main.js",
    "typecheck": "tsc --noEmit",
    "test": "jest --config jest.config.cjs",
    "test:coverage": "jest --config jest.config.cjs --coverage",
    "test:integration": "dotenv -e ../../.env.local -- jest --config jest.integration.config.cjs --runInBand"
  },
  "dependencies": {
    "@aps/db": "workspace:*",
    "@aps/engine": "workspace:*",
    "@aps/shared-types": "workspace:*",
    "@nestjs/common": "10.4.19",
    "@nestjs/core": "10.4.19",
    "@nestjs/jwt": "10.2.0",
    "@nestjs/passport": "10.0.3",
    "@nestjs/platform-express": "10.4.19",
    "bcrypt": "5.1.1",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "10.4.9",
    "@nestjs/schematics": "10.2.3",
    "@nestjs/testing": "10.4.19",
    "@types/bcrypt": "5.0.2",
    "@types/express": "5.0.3",
    "@types/jest": "29.5.14",
    "@types/node": "20.19.0",
    "@types/passport-jwt": "4.0.1",
    "jest": "29.7.0",
    "ts-jest": "29.2.5",
    "typescript": "5.4.5"
  }
}
