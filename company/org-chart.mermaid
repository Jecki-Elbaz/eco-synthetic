flowchart TD
    %% Solid = reporting. Dashed = communication (arrowheads show direction).
    %% Cross-group comms only via the two VPs. CEO may reach anyone but defaults to chain of command.
    %% Sami (SME) is on-demand per project, advisory; not drawn as a fixed node.

    OWNER(["jecki - Owner - L1"])
    ECO["Eco - CEO - L2 - P1"]

    subgraph OFFICE["Owner office"]
      LUCI["Luci - Devil's Advocate - P1"]
      EREZ["Erez - Investor - on-demand"]
    end

    subgraph STAFF["CEO staff (direct to CEO)"]
      DALIA["Dalia - Quality & Gov - L3 - P1"]
      ANAT["Anat - HR / Agent-Ops - L3 - P1"]
      ASSAF["Assaf - Operational Excellence - L3 - P1"]
      RAMBO["Rambo - Security - L3 - P1"]
      EYAL["Eyal - Legal - L3 - P1"]
      LITAL["Lital - CFO - L3 - P1"]
      NOAM["Noam - Product - L3 - P1"]
      ZVIKA["Zvika - Research - L3 - P2 - gated"]
    end

    subgraph RND["VP R&D group"]
      IDO["Ido - VP R&D - L3 - P1"]
      GAL["Gal - Lead Developer - L4 - P1"]
      SHIR["Shir - DevOps - L4 - P1"]
      ADI["Adi - QA - L4 - P2"]
      SENIOR["Senior Developer - L4 - P2"]
      ROMAN["Roman - Algorithm Spec - L4 - P2 - on-demand"]
    end

    subgraph CSG["VP Customer Success group"]
      MIKE["Mike - VP CS - L3 - P3"]
      JENNY["Jenny - Support - L4 - P3"]
      AVNER["Avner - Customer Success - L4 - P3"]
      ELLA["Ella - Customer Training - L4 - P3"]
    end

    subgraph SALESG["VP Sales group"]
      TIM["Tim - VP Sales - L3 - P3"]
      ALEX["Alex - Sales - L4 - P3"]
      HILA["Hila - Marketing - L4 - P1 light"]
    end

    GATE{{"Tool adoption gate"}}
    HUB[("Shared memory: board + log + KB")]

    OWNER --> ECO
    OWNER --> LUCI
    OWNER --> EREZ
    ECO --> DALIA
    ECO --> ANAT
    ECO --> ASSAF
    ECO --> RAMBO
    ECO --> EYAL
    ECO --> LITAL
    ECO --> NOAM
    ECO --> ZVIKA
    ECO --> IDO
    ECO --> MIKE
    ECO --> TIM
    IDO --> GAL
    IDO --> SHIR
    IDO --> ADI
    IDO --> SENIOR
    IDO --> ROMAN
    MIKE --> JENNY
    MIKE --> AVNER
    MIKE --> ELLA
    TIM --> ALEX
    TIM --> HILA

    OWNER <-.->|"company matters"| ECO
    LUCI -.->|"challenge (capped)"| ECO
    IDO <-.->|"requirements / feasibility"| NOAM
    MIKE <-.->|"customer feedback / roadmap"| NOAM
    GAL <-.->|"code review (max 2 rounds)"| SENIOR
    ADI -.->|"recurring-bug pattern"| GAL
    ADI -.->|"quality trends"| DALIA
    RAMBO -.->|"risk"| GATE
    EYAL -.->|"terms"| GATE
    GATE -.->|"borderline = A1"| OWNER
    ASSAF <-.->|"usage + fitness"| HUB
    ECO -.->|"orchestrates"| HUB
    ZVIKA -.->|"on authorized request"| ECO
