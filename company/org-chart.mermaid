flowchart TD
    %% Solid = reporting. Dashed = communication (arrowheads show direction).
    %% Cross-group comms only via the VPs. CEO may reach anyone but defaults to chain of command.
    %% Maintained by Anat (HR/Agent-Ops): update after EACH agent add/retire/rename/re-scope A1.
    %% Last updated 2026-06-28 (owner A1): Noam->Perry, Tim->Sally, Avner->Jack, Senior Dev->Oren;
    %% added Oracle, Yael, Yossi, Red (RedTeam), Designer, Sami, MeetingPrep. Shelly = separated (customer).

    OWNER(["jecki - Owner - L1"])
    ECO["Eco - CEO - L2 - P1"]
    SHELLY_X["Shelly - Office Mgr - SEPARATED to own repo (Eco customer)"]

    subgraph OFFICE["Owner office"]
      LUCI["Luci - Devil's Advocate - P1 - on-demand"]
      EREZ["Erez - Investor - on-demand"]
    end

    subgraph STAFF["CEO staff (direct to CEO)"]
      DALIA["Dalia - Quality & Gov - L3 - P1"]
      ANAT["Anat - HR / Agent-Ops - L3 - P1"]
      ASSAF["Assaf - Operational Excellence - L3 - P1"]
      RAMBO["Rambo - Security - L3 - P1"]
      EYAL["Eyal - Legal - L3 - P1"]
      LITAL["Lital - CFO - L3 - P1"]
      PERRY["Perry - VP Product - L3 - P1 (was Noam)"]
      ORACLE["Oracle - Build-historian - L3 - pulled-fwd"]
      ZVIKA["Zvika - Research - L3 - P2 - gated/on-demand"]
      YAEL["Yael - Knowledge/Doc - L4 - P2 (under Dalia)"]
      YOSSI["Yossi - Training/Enablement - L4 - P2 (under Assaf)"]
      RED["Red - RedTeam Security Tester - L4 - P1 - on-demand, no Bash (under Rambo)"]
      DESIGNER["Designer (Tal) - Product UX/UI - L4 - P2 (under Perry)"]
      SAMI["Sami - SME advisor - L4 - on-demand per-project (under Perry)"]
    end

    subgraph RND["VP R&D group"]
      IDO["Ido - VP R&D - L3 - P1"]
      GAL["Gal - Lead Developer - L4 - P1"]
      SHIR["Shir - DevOps - L4 - P1"]
      ADI["Adi - QA - L4 - P2"]
      OREN["Oren - Senior Developer - L4 - P2"]
      NOA["Noa - Senior Developer 2 (APS) - L4 - P1"]
      ROMAN["Roman - Algorithm Spec - L4 - P2 - on-demand"]
    end

    subgraph CSG["VP Customer Success group"]
      MIKE["Mike - VP CS - L3 - P3"]
      JENNY["Jenny - Support - L4 - P3"]
      JACK["Jack - CS Manager + Account Mgr - L4 - P3 (was Avner)"]
      ELLA["Ella - Customer Training - L4 - P3"]
    end

    subgraph SALESG["VP Sales group"]
      SALLY["Sally - VP Sales - L3 - P3 (was Tim)"]
      ALEX["Alex - Sales - L4 - P3"]
      HILA["Hila - Marketing - L4 - P1 light"]
      MEETINGPREP["MeetingPrep - Meeting-prep Specialist - L4 - P3 - on-demand"]
    end

    GATE{{"Tool adoption gate"}}
    HUB[("Shared memory: board + log + KB")]

    OWNER --> ECO
    OWNER --> LUCI
    OWNER --> EREZ
    OWNER -.->|"separated; now a customer"| SHELLY_X
    ECO --> DALIA
    ECO --> ANAT
    ECO --> ASSAF
    ECO --> RAMBO
    ECO --> EYAL
    ECO --> LITAL
    ECO --> PERRY
    ECO --> ORACLE
    ECO --> ZVIKA
    ECO --> IDO
    ECO --> MIKE
    ECO --> SALLY
    DALIA --> YAEL
    ASSAF --> YOSSI
    RAMBO --> RED
    PERRY --> DESIGNER
    PERRY --> SAMI
    IDO --> GAL
    IDO --> SHIR
    IDO --> ADI
    IDO --> OREN
    IDO --> NOA
    IDO --> ROMAN
    MIKE --> JENNY
    MIKE --> JACK
    MIKE --> ELLA
    SALLY --> ALEX
    SALLY --> HILA
    SALLY --> MEETINGPREP

    OWNER <-.->|"company matters"| ECO
    LUCI -.->|"challenge (capped)"| ECO
    IDO <-.->|"requirements / feasibility"| PERRY
    MIKE <-.->|"customer feedback / roadmap"| PERRY
    GAL <-.->|"code review (max 2 rounds)"| OREN
    ADI -.->|"recurring-bug pattern"| GAL
    ADI -.->|"quality trends"| DALIA
    ORACLE -.->|"chronicle (dotted)"| DALIA
    YOSSI -.->|"dotted"| ANAT
    RAMBO -.->|"risk"| GATE
    EYAL -.->|"terms"| GATE
    GATE -.->|"borderline = A1"| OWNER
    ASSAF <-.->|"usage + fitness"| HUB
    ECO -.->|"orchestrates"| HUB
    ZVIKA -.->|"on authorized request"| ECO
