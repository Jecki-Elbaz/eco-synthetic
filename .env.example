# Environment variable names only -- no real values here.
# Copy to .env at repo root and fill in. Never commit .env.

# Claude Max subscription auth (OAuth token -- NOT an API key).
# Run: claude setup-token
# See integrations/telegram-bridge/README.md for headless setup.
# DO NOT add ANTHROPIC_API_KEY -- the bridge refuses to start if it finds one.
CLAUDE_CODE_OAUTH_TOKEN=

# Telegram bot token from BotFather -- see company/setup-guide.md section 2.
ECO_TELEGRAM_BOT_TOKEN=
